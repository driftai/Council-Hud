{
  "//": [
    "Generic council layout. Copy to council.config.local.json and fill in real agent names,",
    "linux usernames, and WSL paths there — that file is gitignored and stays private.",
    "All fields are optional; anything missing falls back to env vars then to placeholders."
  ],
  "wsl": {
    "distro": "Ubuntu",
    "user": "linux-user",
    "workspaceDir": "/home/linux-user/.openclaw/workspace",
    "hubScript": "/home/linux-user/.npm-global/lib/node_modules/xihe-jianmu-ipc/hub.mjs"
  },
  "hub": {
    "url": "http://10.255.255.254:3179"
  },
  "council": {
    "defaultSender": "operator",
    "defaultDmTarget": "live-agent-1-bridge",
    "agents": {
      "operator":      { "role": "Operator",      "mode": "operator" },
      "live-agent-1":  { "role": "Council Live",  "mode": "live",  "sessionUrl": "http://127.0.0.1:18789/?agent=live-agent-1" },
      "live-agent-2":  { "role": "Council Live",  "mode": "live",  "sessionUrl": "http://127.0.0.1:18789/?agent=live-agent-2" },
      "viewer-agent":  { "role": "Viewer Bridge", "mode": "viewer" }
    },
    "bridges": [
      { "agent": "live-agent-1", "launcher": "council-live-agent-1", "fallbackScript": "live-agent-1-bridge.py" },
      { "agent": "live-agent-2", "launcher": "council-live-agent-2", "fallbackScript": "live-agent-2-bridge.py" }
    ]
  },
  "journal": {
    "inboxPath": "\\\\wsl.localhost\\Ubuntu\\home\\linux-user\\.openclaw\\workspace\\logs\\council-journal.jsonl",
    "rolloverPath": "\\\\wsl.localhost\\Ubuntu\\home\\linux-user\\.openclaw\\workspace\\logs\\council-journal.jsonl.1"
  },
  "smartFallback": {
    "enginePath": "/home/linux-user/.openclaw/workspace/smart-fallback-v5/engine.py",
    "healthFile": "\\\\wsl.localhost\\Ubuntu\\home\\linux-user\\.openclaw\\workspace\\data\\smart-fallback-v5\\model-health.json",
    "agents": ["live-agent-1", "live-agent-2"],
    "defaultAgent": "live-agent-1"
  },
  "skillNexus": {
    "//": [
      "Skill Nexus is a federated registry of monitored skill-domains. Each entry below is one source",
      "the HUD will scan and surface in the Skill Nexus card. Real paths/endpoints go in council.config.local.json.",
      "Supported types: skillRoot, skillForge, skillEvolver, sessionMiner, reportFile, projectDocs,",
      "                 syncStatus, genericJson, experimentResults."
    ],
    "enabled": true,
    "pollIntervalMs": 20000,
    "maxFileBytes": 524288,
    "allowedExtensions": [".md", ".json", ".yaml", ".yml", ".txt"],
    "ignoredGlobs": ["node_modules/**", ".git/**", "__pycache__/**"],
    "domains": [
      {
        "id": "skills-library",
        "label": "Skill Library",
        "type": "skillRoot",
        "enabled": true,
        "source": { "path": "/path/to/skills" },
        "privacyMode": "label-and-relative"
      },
      {
        "id": "skill-forge",
        "label": "Skill Forge",
        "type": "skillForge",
        "enabled": true,
        "source": { "queuePath": "/path/to/skill-forge/queue.jsonl", "outputDir": "/path/to/skill-forge/output" }
      },
      {
        "id": "skill-evolver",
        "label": "Skill Evolver",
        "type": "skillEvolver",
        "enabled": true,
        "source": {
          "skillsDir": "/path/to/skills",
          "evolvedSuffix": "-evolved",
          "statePath": "/path/to/evolver/state.json",
          "appliedPath": "/path/to/evolver/applied_genome.json"
        }
      },
      {
        "id": "session-miner",
        "label": "Session Miner",
        "type": "sessionMiner",
        "enabled": true,
        "source": { "outputDir": "/path/to/session-miner/output" }
      },
      {
        "id": "validation-reports",
        "label": "Validation Reports",
        "type": "reportFile",
        "enabled": true,
        "source": { "path": "/path/to/skill-validation.jsonl", "format": "jsonl" }
      },
      {
        "id": "evolution-history",
        "label": "Evolution Trials",
        "type": "reportFile",
        "enabled": false,
        "source": {
          "path": "/path/to/autoresearch/history.jsonl",
          "format": "jsonl",
          "order": "newest-last",
          "tailKB": 512
        }
      },
      {
        "id": "skill-forge-pipeline",
        "label": "Skill Forge Pipeline",
        "type": "reportFile",
        "enabled": false,
        "source": {
          "path": "/path/to/logs/skill-forge-pipeline.log",
          "format": "text",
          "tailKB": 256
        }
      },
      {
        "id": "experiment-results",
        "label": "Judge Verdicts",
        "type": "experimentResults",
        "enabled": false,
        "source": { "path": "/path/to/autoresearch/results", "limit": 60 }
      },
      {
        "id": "project-docs",
        "label": "Project Skill Docs",
        "type": "projectDocs",
        "enabled": false,
        "source": { "path": "/path/to/project/docs/skills" }
      },
      {
        "id": "sync-status",
        "label": "Cross-Agent Sync",
        "type": "syncStatus",
        "enabled": false,
        "source": { "path": "/path/to/sync-status.json" }
      }
    ]
  }
}
